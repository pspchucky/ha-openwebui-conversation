            "rgb": {
              "type": "array",
              "items": { "type": "integer" }
            }
          },
          "required": ["names", "state"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "home_assistant_tool/wait",
        "description": "Pause before the next action in a multi-step plan",
        "parameters": {
          "type": "object",
          "properties": {
            "seconds": {
              "type": "integer",
              "minimum": 0,
              "maximum": 60
            }
          },
          "required": ["seconds"]
        }
      }
    }
